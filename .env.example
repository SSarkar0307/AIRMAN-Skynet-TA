# Local development defaults
DATABASE_URL=sqlite+pysqlite:///./airman.db
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_CONNECT_RETRIES=5
DATABASE_CONNECT_RETRY_DELAY_SECONDS=2

